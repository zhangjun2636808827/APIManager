{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "API Manager",
  "version": "0.1.0",
  "identifier": "com.codex.apimanager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "API Manager",
        "label": "main",
        "width": 1320,
        "height": 860,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "digestAlgorithm": "sha256"
    }
  }
}
